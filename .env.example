# Supabase project credentials used by the metrics reporter (reporter.py).
# If either is absent, canvs_report() falls back to writing local JSONL
# files under CANVS_RUNS_DIR/{run_id}.jsonl — no crash, no network call.
SUPABASE_URL=
SUPABASE_KEY=

# Directory where local runs write their compiled script, log, and
# fallback JSONL metrics files. Defaults to ./canvs_runs if unset.
CANVS_RUNS_DIR=./canvs_runs

# Comma-separated list of importable modules whose @node-decorated
# functions should be registered on server startup.
CANVS_NODE_MODULES=examples.toy_nodes
